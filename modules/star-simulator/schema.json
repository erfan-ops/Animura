{
  "fps": {
    "type": "float",
    "min": 1,
    "max": 240,
    "step": 1
  },

  "vsync": {
    "type": "bool"
  },

  "background-colors": {
    "type": "color_list"
  },

  "stars": {
    "segments": {
      "type": "int",
      "min": 3,
      "max": 64
    },

    "radius": {
      "type": "float",
      "min": 0.1,
      "max": 100
    },

    "count": {
      "type": "int",
      "min": 1,
      "max": 5000
    },

    "min-speed": {
      "type": "float",
      "min": 0,
      "max": 500
    },

    "max-speed": {
      "type": "float",
      "min": 0,
      "max": 500
    },

    "color": {
      "type": "color"
    }
  },

  "lines": {
    "color": {
      "type": "color"
    },
    "min-width": {
      "type": "float",
      "min": 0,
      "max": 10
    },
    "max-width": {
      "type": "float",
      "min": 0,
      "max": 10
    }
  },

  "max-line-distance": {
    "type": "float",
    "min": 1,
    "max": 1000
  },

  "offset-bounds": {
    "type": "float",
    "min": 1,
    "max": 1000
  },

  "MSAA": {
    "type": "select",
    "options": [0, 2, 4, 8, 16]
  }
}
